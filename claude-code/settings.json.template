{
  "effortLevel": "high",
  "model": "opus[1m]",
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "mcp__codex__codex",
      "mcp__gemini__gemini",
      "mcp__groksearch__web_search",
      "mcp__groksearch__search_planning",
      "mcp__groksearch__get_sources"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/scripts/session-context.py",
            "type": "command",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/scripts/keyword-detector.py",
            "type": "command",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/scripts/project-memory.py",
            "type": "command",
            "timeout": 5000
          }
        ],
        "matcher": "tool == \"Edit\" || tool == \"Write\" || tool == \"Bash\""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/scripts/stop-persistence.py",
            "type": "command",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
